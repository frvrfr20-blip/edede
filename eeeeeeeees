        window.searchFrame.Position = UDim2.fromOffset(702, 110)
        window.searchFrame.Size = UDim2.fromOffset(208, 34)
        setCorner(window.searchFrame, 18)
        setStroke(window.searchFrame, Theme.BorderSoft, 1)
        if window.searchBox then
            window.searchBox.TextSize = 12
        end
    end

    local function syncSearchState()
        if not window.searchFrame then
            return
        end

        local active = window.searchFrame.Visible == true
        tween(searchButton, {
            BackgroundColor3 = active and Theme.SurfaceSoft or Theme.Surface
        }, 0.12)
        tween(searchIcon, {
            ImageColor3 = active and window.config.AccentColor or Color3.fromRGB(236, 236, 241)
        }, 0.12)
    end

    searchButton.MouseButton1Click:Connect(function()
        if not window.searchFrame then
            return
        end

        window.searchFrame.Visible = not window.searchFrame.Visible
        if window.searchFrame.Visible and window.searchBox then
            pcall(function()
                window.searchBox:CaptureFocus()
            end)
        end
        syncSearchState()
    end)
    searchButton.MouseEnter:Connect(function()
        if not window.searchFrame or not window.searchFrame.Visible then
            tween(searchButton, {BackgroundColor3 = Theme.SurfaceSoft}, 0.12)
        end
    end)
    searchButton.MouseLeave:Connect(function()
        if not window.searchFrame or not window.searchFrame.Visible then
            tween(searchButton, {BackgroundColor3 = Theme.Surface}, 0.12)
        end
    end)

    if window.searchBox then
        window.searchBox.FocusLost:Connect(function()
            if window.searchFrame and window.searchFrame.Visible then
                window.searchFrame.Visible = false
                syncSearchState()
            end
        end)
    end

    registerRefresh(window, syncSearchState)
    styleSettingsPanel(window, gearBubble)
end

local function patchTab(tab, window, section)
    if not tab or tab._v2Patched then
        return
    end

    tab._v2Patched = true
    resizeTabColumns(tab)
    tab._v2Section = section

    local baseActivate = tab.Activate
    function tab:Activate(...)
        baseActivate(self, ...)
        activateTab(window, self)
        resizeTabColumns(self)
    end

    local baseAddGroup = tab.AddGroup
    function tab:AddGroup(config)
        local group = baseAddGroup(self, config)
        resizeTabColumns(self)
        patchGroup(group, window)
        group.mainFrame.Size = UDim2.fromOffset(Layout.GroupWidth, group.mainFrame.Size.Y.Offset)
        return group
    end
end

local function patchSection(section, window, config)
    if not section or section._v2Patched then
        return
    end

    section._v2Patched = true
    section._v2Tabs = {}
    if section.containerFrame then
        section.containerFrame.Visible = false
    end
    createSidebarButton(window, section, config and config.Icon)

    local baseAddTab = section.AddTab
    function section:AddTab(tabConfig)
        local tab = baseAddTab(self, tabConfig)
        table.insert(self._v2Tabs, tab)
        patchTab(tab, window, self)
        createTabButton(window, self, tab, tabConfig)
        if not window._v2ActiveSection then
            activateSection(window, self, false)
        else
            refreshTabStates(window)
        end
        task.defer(function()
            if window._v2ActiveSection == self and not window.currentTabYay and self._v2Tabs[1] then
                pcall(function()
                    self._v2Tabs[1]:Activate()
                end)
            end
        end)
        return tab
    end
end

local function styleWindow(window)
    if not window then
        return
    end

    window._v2Sections = {}
    window._v2RefreshCallbacks = {}
    buildShell(window)

    local baseCreateSection = window.CreateSection
    function window:CreateSection(config)
        local section = baseCreateSection(self, config)
        table.insert(self._v2Sections, section)
        patchSection(section, self, config or {})
        refreshSidebarStates(self)
        refreshTabStates(self)
        return section
    end

    if type(window.SetAccentColor) == "function" then
        local baseSetAccentColor = window.SetAccentColor
        function window:SetAccentColor(color, ...)
            baseSetAccentColor(self, color, ...)
            runRefresh(self)
        end
    end

    if type(window.Notify) == "function" then
        local baseNotify = window.Notify
        function window:Notify(config)
            local notificationFrame = baseNotify(self, config)
            styleNotification(notificationFrame, self, config or {})
            return notificationFrame
        end
    end

    runRefresh(window)
end

function BaseLibrary.new(config)
    config = config or {}
    config.Name = config.Name or "Flow // Source 2"
    config.AccentColor = config.AccentColor or Theme.Accent
    config.BackgroundColor = config.BackgroundColor or Theme.Background
    config.SecondaryColor = config.SecondaryColor or Theme.Surface
    config.TextColor = config.TextColor or Theme.Text
    config.SubTextColor = config.SubTextColor or Theme.Muted

    local window = baseNew(config)
    styleWindow(window)
    return window
end

return BaseLibrary
