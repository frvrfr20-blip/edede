local function make(className, props)
    local instance = Instance.new(className)
    for property, value in pairs(props) do
        instance[property] = value
    end
    return instance
end

local function findFirstChildOfClass(parent, className)
    if not parent then
        return nil
    end

    for _, child in ipairs(parent:GetChildren()) do
        if child.ClassName == className then
            return child
        end
    end

    return nil
end

local function setCorner(target, radius)
    if not target then
        return
    end

    local corner = findFirstChildOfClass(target, "UICorner")
    if not corner then
        corner = make("UICorner", {Parent = target})
    end
    corner.CornerRadius = UDim.new(0, radius)
end

local function setStroke(target, color, thickness, transparency)
    if not target then
        return
    end

    local stroke = findFirstChildOfClass(target, "UIStroke")
    if not stroke then
        stroke = make("UIStroke", {Parent = target})
    end
    stroke.Color = color
    stroke.Thickness = thickness or stroke.Thickness or 1
    if transparency ~= nil then
        stroke.Transparency = transparency
    end
end

local function styleText(label, color, size)
    if not label then
        return
    end

    label.TextColor3 = color or label.TextColor3
    if size then
        label.TextSize = size
    end
    pcall(function()
        label.Font = Enum.Font.GothamSemibold
    end)
end

local function tween(instance, properties, duration)
    if not instance or not instance.Parent then
        return
    end

    pcall(function()
        TweenService:Create(instance, TweenInfo.new(duration or 0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), properties):Play()
    end)
end

local function measureText(text, size)
    local ok, bounds = pcall(function()
        return TextService:GetTextSize(tostring(text or ""), size, Enum.Font.GothamSemibold, Vector2.new(1000, 1000))
    end)

    if ok and bounds then
        return bounds.X
    end

    return math.max(60, (#tostring(text or "")) * math.max(6, math.floor(size * 0.52)))
end

local function registerRefresh(window, callback)
    window._v2RefreshCallbacks = window._v2RefreshCallbacks or {}
    table.insert(window._v2RefreshCallbacks, callback)
end

local function runRefresh(window)
    for _, callback in ipairs(window._v2RefreshCallbacks or {}) do
        pcall(callback)
    end
end

local function clampFloatingFrame(window, frame, padding)
    if not frame or frame._v2ClampBound then
        return
    end

    frame._v2ClampBound = true
    local inset = padding or 18

    local function clampNow()
        local main = window and (window._v2MainFrame or window.mainFrameYay)
        if not main or not main.Parent or not frame.Parent then
            return
        end

        local frameSize = frame.AbsoluteSize
        local mainPos = main.AbsolutePosition
        local mainSize = main.AbsoluteSize
        if frameSize.X <= 0 or frameSize.Y <= 0 or mainSize.X <= 0 or mainSize.Y <= 0 then
            return
        end

        local minX = mainPos.X + inset
        local minY = mainPos.Y + inset
        local maxX = math.max(minX, (mainPos.X + mainSize.X) - frameSize.X - inset)
        local maxY = math.max(minY, (mainPos.Y + mainSize.Y) - frameSize.Y - inset)
        local clampedX = math.floor(math.clamp(frame.AbsolutePosition.X, minX, maxX) + 0.5)
        local clampedY = math.floor(math.clamp(frame.AbsolutePosition.Y, minY, maxY) + 0.5)

        if frame.Position.X.Scale ~= 0 or frame.Position.Y.Scale ~= 0
            or frame.Position.X.Offset ~= clampedX or frame.Position.Y.Offset ~= clampedY then
            frame.Position = UDim2.fromOffset(clampedX, clampedY)
        end
    end

    frame:GetPropertyChangedSignal("Position"):Connect(function()
        task.defer(clampNow)
    end)
    frame:GetPropertyChangedSignal("Size"):Connect(function()
        task.defer(clampNow)
    end)
    frame:GetPropertyChangedSignal("Visible"):Connect(function()
        task.defer(clampNow)
    end)

    registerRefresh(window, function()
        task.defer(clampNow)
    end)
    task.defer(clampNow)
end

