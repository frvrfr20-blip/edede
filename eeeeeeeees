local function refreshSidebarStates(window)
    for _, section in ipairs(window._v2Sections or {}) do
        local active = section == window._v2ActiveSection
        if section._v2SidebarButton then
            section._v2SidebarButton.BackgroundTransparency = active and 0 or 1
            section._v2SidebarButton.BackgroundColor3 = active and Theme.SurfaceSoft or Theme.Surface
        end
        if section._v2SidebarIcon then
            section._v2SidebarIcon.ImageColor3 = active and Theme.Text or Theme.Muted
        end
        if section._v2SidebarAccent then
            section._v2SidebarAccent.Visible = active
        end
        if section._v2SidebarGlow then
            section._v2SidebarGlow.ImageTransparency = active and 0.82 or 1
        end
    end
end

local function refreshTabStates(window)
    for _, section in ipairs(window._v2Sections or {}) do
        for _, tab in ipairs(section._v2Tabs or {}) do
            local visible = section == window._v2ActiveSection
            if tab._v2TabButton then
                tab._v2TabButton.Visible = visible
                if visible then
                    local active = window.currentTabYay == tab
                    tab._v2TabButton.BackgroundColor3 = active and Theme.SurfaceRaised or Theme.Surface
                    if tab._v2TabButtonLabel then
                        tab._v2TabButtonLabel.TextColor3 = active and Theme.Text or Theme.Muted
                    end
                end
            end
        end
    end
end

local function activateSection(window, section, skipTabActivation)
    if not section then
        return
    end

    window._v2ActiveSection = section
    refreshSidebarStates(window)
    refreshTabStates(window)

    if not skipTabActivation then
        local tab = section._v2LastActiveTab or section._v2Tabs[1]
        if tab then
            tab:Activate()
        end
    end
end

local function activateTab(window, tab)
    if not tab then
        return
    end

    local section = tab._v2Section
    if section then
        window._v2ActiveSection = section
        section._v2LastActiveTab = tab
    end

    refreshSidebarStates(window)
    refreshTabStates(window)
end

