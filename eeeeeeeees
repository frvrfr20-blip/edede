local function styleSettingsPanel(window, triggerButton)
    local panel = window.uiSettingsPanelFrame
    if not panel or panel._v2Styled then
        return
    end

    panel._v2Styled = true
    panel.AnchorPoint = Vector2.new(0, 0)
    panel.Position = UDim2.fromOffset(Layout.WindowWidth - 220, 86)
    panel.Size = UDim2.fromOffset(192, 0)
    panel.BackgroundColor3 = Theme.Surface
    panel.ClipsDescendants = true
    setCorner(panel, 20)
    setStroke(panel, Theme.Border, 1.1)

    local targetHeight = 240
    for _, child in ipairs(panel:GetChildren()) do
        if child:IsA("GuiObject") then
            targetHeight = math.max(targetHeight, child.Position.Y.Offset + child.Size.Y.Offset + 14)
        end
        if child:IsA("TextLabel") then
            styleText(child, child.Text == "UI Tweaks" and Theme.Text or Theme.Muted, child.Text == "UI Tweaks" and 13 or 12)
        elseif child:IsA("Frame") and child ~= panel then
            if child.Size.X.Offset <= 18 and child.Size.Y.Offset <= 18 then
                setStroke(child, Theme.Border, 1)
            elseif child.Size.X.Offset <= 36 and child.Size.Y.Offset <= 18 then
                setCorner(child, 10)
            end
        end
    end

    if window.uiAccentPreviewFrame then
        bindAccent(window, window.uiAccentPreviewFrame)
    end
    clampFloatingFrame(window, panel, 18)

    local function setOpen(openState)
        window.uiSettingsOpen = openState == true
        if window.uiSettingsOpen then
            panel.Visible = true
            tween(panel, {Size = UDim2.fromOffset(192, targetHeight)}, 0.18)
            if triggerButton then
                tween(triggerButton, {BackgroundColor3 = Theme.SurfaceSoft}, 0.14)
            end
        else
            tween(panel, {Size = UDim2.fromOffset(192, 0)}, 0.16)
            if triggerButton then
                tween(triggerButton, {BackgroundColor3 = Theme.Surface}, 0.14)
            end
            task.delay(0.16, function()
                if panel and panel.Parent and not window.uiSettingsOpen then
                    panel.Visible = false
                end
            end)
        end
    end

    if triggerButton then
        triggerButton.MouseButton1Click:Connect(function()
            setOpen(not window.uiSettingsOpen)
        end)
        triggerButton.MouseEnter:Connect(function()
            if not window.uiSettingsOpen then
                tween(triggerButton, {BackgroundColor3 = Theme.SurfaceSoft}, 0.12)
            end
        end)
        triggerButton.MouseLeave:Connect(function()
            if not window.uiSettingsOpen then
                tween(triggerButton, {BackgroundColor3 = Theme.Surface}, 0.12)
            end
        end)
    end

    registerRefresh(window, function()
        panel.BackgroundColor3 = Theme.Surface
        setStroke(panel, Theme.Border, 1.1)
        if window.uiAccentPreviewFrame and window.uiAccentPreviewFrame.Parent then
            window.uiAccentPreviewFrame.BackgroundColor3 = window.config.AccentColor
        end
    end)
end

